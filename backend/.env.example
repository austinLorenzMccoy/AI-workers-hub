# Supabase project URL (e.g. https://xxxxxxxxxxxx.supabase.co for cloud, or http://127.0.0.1:54321 for local CLI)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Supabase Service Role Key (server-only, bypasses RLS. Never expose this key!)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Application URL configurations
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Edge Functions variables
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T...
NOTIFICATION_EMAIL=ops@yourcompany.com
